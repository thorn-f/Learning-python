import random
import time
from datetime import datetime 

class BBplayer:
    def __init__(self, name, age, team):
        self.name = name
        self.age = age
        self.team = team
        self.points = 0    
        self.rebounds = 0
        self.assists = 0   

    def display_info(self):
        print(f"Name: {self.name}, Age: {self.age}, Team: {self.team}")


name = input("Enter player's name: ")
age = int(input("Enter player's age: "))
team = input("Enter player's team: ")

player = BBplayer(name, age, team)
player.display_info()


while True:
    first_match_date = input("Enter the date of the player's first match (YYYY-MM-DD): ")
    try:
        
        valid_date = datetime.strptime(first_match_date, "%Y-%m-%d")
        
        print(f"Match date confirmed: {valid_date.strftime('%B %d, %Y')}")
        break 
    except ValueError:
        print("Invalid date format. Please enter the date in YYYY-MM-DD format.")

print(f"{player.name}'s first match date is {first_match_date}.")

time.sleep(3)

print("It's game time!")

def simulate_game(player):

    quarter_stats = []

    for i in range(4):  # 4 quarters
        print(f"Quarter {i+1} starting...")
        time.sleep(2)  # Simulate time for the quarter        
        points = random.randint(2, 15)
        rebounds = random.randint(0, 10)
        assists = random.randint(0, 10)

        
        player.points += points
        player.rebounds += rebounds
        player.assists += assists

        quarter_stats.append((i + 1, points, rebounds, assists))

        print(f"Quarter {i+1} stats - Points: {points}, Rebounds: {rebounds}, Assists: {assists}")
        time.sleep(1)

    best_quarter = max(quarter_stats, key=lambda x: x[1])
    print(f"Best quarter so far: {best_quarter[1]} points in Quarter {best_quarter[0]}")

    return quarter_stats

game_stats = simulate_game(player)
print(f"Final Stats for {player.name} - Points: {player.points}, Rebounds: {player.rebounds}, Assists: {player.assists}")
 